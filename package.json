{
  "name": "termchat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A terminal-based social chat app — Ink TUI client + Node WebSocket server",
  "bin": {
    "termchat": "dist/client/index.js",
    "termchat-server": "dist/server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "server": "node dist/server/index.js",
    "client": "node dist/client/index.js",
    "start": "node dist/server/index.js",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "tsx src/client/index.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "ink": "^5.0.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-notifier": "^10.0.1",
    "react": "^18.3.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
